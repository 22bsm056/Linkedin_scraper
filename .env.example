# .env.example

# General Settings
API_KEY=your_secure_api_key_here

# Comma-separated list of proxy URLs (http://user:pass@host:port)
PROXIES=

# LinkedIn Authentication (Primary)
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

# Request rate limits
RATE_LIMIT_MAX_PER_COOKIE=100

# Additional credentials for specific modules
EMAIL=your_email@example.com
PASSWORD=your_password
OPENAI_API_KEY=sk-proj-placeholder
GROQ_API_KEY=gsk_placeholder
GROQ_MODEL=openai/gpt-oss-120b
